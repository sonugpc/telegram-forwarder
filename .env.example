# ─────────────────────────────────────────────
#  Telegram MTProto Credentials
#  Get these from https://my.telegram.org/apps
# ─────────────────────────────────────────────
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Path to persist the session string (auto-created on first login)
TELEGRAM_SESSION_FILE=./session.json

# ─────────────────────────────────────────────
#  Express Server
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
#  Logging  (error | warn | info | debug)
# ─────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────
#  Routes Config
# ─────────────────────────────────────────────
ROUTES_CONFIG_PATH=./config/routes.json

# ─────────────────────────────────────────────
#  Affiliate API Processing
# ─────────────────────────────────────────────
# JWT token for the processing microservice (sent as 'authX' header)
PROCESSING_AUTH_TOKEN=your_jwt_token

# ─────────────────────────────────────────────
#  WhatsApp (WAHA) Integration
# ─────────────────────────────────────────────
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_waha_key_here

# ─────────────────────────────────────────────
#  Global Settings
# ─────────────────────────────────────────────
# If set, secures the Admin UI with HTTP Basic Auth (username: admin)
ADMIN_PASSWORD=admin123

# Appended to the bottom of every forwarded message
GLOBAL_TAGLINE=Join our premium channel for more deals!
